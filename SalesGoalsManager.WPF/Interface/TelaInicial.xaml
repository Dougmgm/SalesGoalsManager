<Window x:Class="ProjetoCadastros.Interface.TelaInicial"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjetoCadastros.Interface"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Bem vindo" Height="450" Width="815"
        Background="#334355">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height=".5*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height=".2*"/>
            <RowDefinition Height=".5*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0"
             Grid.Row="0"
            Grid.ColumnSpan="4"
            Height="25">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Name="tbBuscarMeta"
                     Text="{Binding Tela.TextoDeBusca}"
                     Grid.Column="0"
                     VerticalAlignment="Stretch"
                     Margin="0, 0, 5, 0"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="IMAGEM"
                        Name="btnLimparBusca"
                        Height="25"
                        Width="25"
                        Background="White"
                        Command="{Binding [LimparBusca]}"
                        Margin="0, 0, 5, 0"/>
                <Button Content="Buscar (F11)"
                        Name="btnBuscar"
                        Height="25"
                        Width="100"
                        Background="DarkCyan"
                        Command="{Binding [BuscarMeta]}"
                        FontFamily="Montserrat"
                        Foreground="White"
                        BorderBrush="White"/>
            </StackPanel>

        </Grid>

        <DataGrid Grid.Row="1"
                  Grid.RowSpan="4"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  ItemsSource="{Binding ListaFiltrada}"
                  SelectedItem="{Binding MetaSelecionada}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Vendedor" Binding="{Binding NomeVendedor}" Width="*"/>
                <DataGridTextColumn Header="Periodicidade" Binding="{Binding Periodicidade}" Width="*"/>
                <DataGridTextColumn Header="Produto" Binding="{Binding Produto}" Width="*"/>
                <DataGridTextColumn Header="Tipo de Meta" Binding="{Binding TipoMeta}" Width="*"/>
                <DataGridTextColumn Header="Meta" Binding="{Binding ValorMeta}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Text="teste"
                   Grid.Row="5"
                   Grid.Column="0"/>
                   
        <Button Grid.Column="0"
                Grid.Row="6"
                Content="Excluir"
                Name="btnExcluir"
                Height="25"
                Width="80"
                Command="{Binding [ExcluirMeta]}" 
                HorizontalAlignment="Left"
                Background="Maroon"
                FontFamily="Montserrat"
                Foreground="White"
                BorderBrush="White">
        </Button>

        <StackPanel Grid.Column="2"
                    Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            
            <Button Content="Editar"
                    Margin="0, 0, 15, 0"
                    Background="SteelBlue"
                    Name="btnEditar"
                    Height="25"
                    Width="80"
                    Command="{Binding [EditarMeta]}" 
                    FontFamily="Montserrat"
                    Foreground="White"
                    BorderBrush="White">
            </Button>

            <Button Content="Adicionar [+]"
                    Name="btnAdicionar"
                    Height="25"
                    Width="80"
                    Command="{Binding [CadastrarMeta]}" 
                    Background="Green"
                    FontFamily="Montserrat"
                    Foreground="White"
                    BorderBrush="White">
            </Button>
        </StackPanel>

    </Grid>
</Window>
